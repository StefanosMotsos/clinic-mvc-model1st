@using ClinicApp.Core
@model ClinicApp.DTO.DoctorSignupDTO

@{
    // Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Doctor Signup</title>
</head>
<body>
    <div class="container">
        <main class="w-100 mt-5 p-3 border border-primary mx-auto rounded-3">
            
            <form asp-controller="Doctor" asp-action="Signup" method="POST">
                <div class="row mb-3">
                    <label asp-for="Username" class="col-md-1 col-form-label text-start">Username</label>
                    <div class="col-md-5" style="min-height: 4rem;">
                        <input type="text" class="form-control" asp-for="Username" placeholder="Enter username" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>
                    <label asp-for="Password" class="col-md-1 col-form-label text-start">Password</label>
                    <div class="col-md-5" style="min-height: 4rem;">
                        <input type="password" class="form-control" asp-for="Password" placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <label asp-for="Firstname" class="col-md-1 col-form-label text-start">Firstname</label>
                    <div class="col-md-5" style="min-height: 4rem;">
                        <input type="text" class="form-control" asp-for="Firstname" placeholder="Enter firstname" />
                        <span asp-validation-for="Firstname" class="text-danger"></span>
                    </div>
                    <label asp-for="Lastname" class="col-md-1 col-form-label text-start">Lastname</label>
                    <div class="col-md-5" style="min-height: 4rem;">
                        <input type="text" class="form-control" asp-for="Lastname" placeholder="Enter lastname" />
                        <span asp-validation-for="Lastname" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <label asp-for="Email" class="col-md-1 col-form-label text-start">Email</label>
                    <div class="col-md-5" style="min-height: 4rem;">
                        <input type="text" class="form-control" asp-for="Email" placeholder="Enter email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <label asp-for="PhoneNumber" class="col-md-1 col-form-label text-start">Phone</label>
                    <div class="col-md-5" style="min-height: 4rem;">
                        <input type="text" class="form-control" asp-for="PhoneNumber" placeholder="Enter phone number" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <label asp-for="Specialty" class="col-md-1 col-form-label text-start">Specialty</label>
                    <div class="col-md-5" style="min-height: 4rem;">
                        <input type="text" class="form-control" asp-for="Specialty" placeholder="e.g. Cardiologist" />
                        <span asp-validation-for="Specialty" class="text-danger"></span>
                    </div>
                    <label asp-for="RoleId" class="col-md-1 col-form-label text-start">Role</label>
                    <div class="col-md-5" style="min-height: 4rem;">
                        <select class="form-select" asp-for="RoleId">
                            <option value="3" selected>Doctor</option>
                            <option value="4">Patient</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="offset-md-1 col-md-5 d-grid">
                        <button type="submit" class="btn btn-primary">Sign Up as Doctor</button>
                    </div>
                </div>
            </form>
        </main>
    </div>

    <div class="container mt-3">
        @if (ViewData["ErrorArray"] is not null)
        {
            var errorArray = ViewData["ErrorArray"] as List<Error>;
            if (errorArray != null)
            {
                foreach (var error in errorArray)
                {
                    <div class="alert alert-danger">@error.Message</div>
                }
            }
        }
    </div>
</body>
</html>
